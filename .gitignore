# social build artefacts
# Keep: scripts, README, LAUNCH-CHECKLIST, captions, brand-kit (small), pinterest/pins.csv, fonts
# Exclude: large regeneratable binaries (reels MP4s, pinterest PNGs). Run scripts to rebuild.
social/reels/*.mp4
social/reels/_frames/
social/reels/_build.log
social/reels/_preview*.jpg
social/reels/_preview*.png
social/pinterest/*.png
social/scripts/__pycache__/
__pycache__/
social/reels/_grid-frames/

# enforcement marker files for harness-level gates. NEVER committed —
# committing them would defeat the gate by letting old approval carry
# forward forever after the file content changes. The gate re-fires on
# every fresh content change.
.checks/
.published-url.txt
